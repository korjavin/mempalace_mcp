# Server
PORT=8080
BASE_URL=https://mempalace-mcp.example.com

# Google OIDC
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://mempalace-mcp.example.com/auth/callback
ADMIN_EMAILS=user@example.com
COOKIE_SECRET=change-me-to-random-32-bytes

# Mempalace
PALACE_PATH=/data/palace
# HOME is set to /app in Dockerfile and docker-compose.yml
# so that ~/.mempalace/config.json resolves to /app/.mempalace/config.json
